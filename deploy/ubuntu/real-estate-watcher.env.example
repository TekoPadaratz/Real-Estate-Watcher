NODE_ENV=production
TZ=America/Sao_Paulo
APP_CODE_DIR=/opt/real-estate-watcher
APP_CONFIG_DIR=/opt/real-estate-watcher/config
APP_ENV_FILE=/etc/real-estate-watcher/real-estate-watcher.env
APP_DATA_DIR=/var/lib/real-estate-watcher
APP_CACHE_DIR=/var/cache/real-estate-watcher
APP_DEBUG_DIR=/var/lib/real-estate-watcher/debug
APP_SCREENSHOTS_DIR=/var/lib/real-estate-watcher/debug/screenshots
APP_ARTIFACTS_DIR=/var/lib/real-estate-watcher/debug/artifacts
APP_TMP_DIR=/var/cache/real-estate-watcher/tmp
DATABASE_URL=file:/var/lib/real-estate-watcher/app.db
SEARCH_PROFILE_PATH=/opt/real-estate-watcher/config/search-profile.yaml
SOURCES_CONFIG_PATH=/opt/real-estate-watcher/config/sources.yaml
PLAYWRIGHT_BROWSERS_PATH=/var/lib/real-estate-watcher/pw-browsers
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LOG_LEVEL=info
CRAWL_INTERVAL_MINUTES=60
GLOBAL_SCAN_LOCK_TTL_MINUTES=120
DISPATCHER_IDLE_MS=1000
HTTP_TIMEOUT_MS=30000
HTTP_MAX_PAGINATION_PAGES=10
TELEGRAM_RATE_LIMIT_PER_MINUTE=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
BOOTSTRAP_ON_START=false
ENABLE_LIVE_SMOKE=false
