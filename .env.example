NODE_ENV=development
TZ=America/Sao_Paulo
APP_CODE_DIR=.
APP_CONFIG_DIR=./config
APP_DATA_DIR=./data
APP_CACHE_DIR=./.cache
APP_DEBUG_DIR=./data/debug
APP_SCREENSHOTS_DIR=./data/debug/screenshots
APP_ARTIFACTS_DIR=./data/debug/artifacts
APP_TMP_DIR=./.cache/tmp
DATABASE_URL=file:./data/app.db
PLAYWRIGHT_BROWSERS_PATH=./data/pw-browsers
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LOG_LEVEL=info
CRAWL_INTERVAL_MINUTES=60
GLOBAL_SCAN_LOCK_TTL_MINUTES=120
DISPATCHER_IDLE_MS=1000
HTTP_TIMEOUT_MS=30000
HTTP_MAX_PAGINATION_PAGES=10
TELEGRAM_RATE_LIMIT_PER_MINUTE=10
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
BOOTSTRAP_ON_START=false
ENABLE_LIVE_SMOKE=false
