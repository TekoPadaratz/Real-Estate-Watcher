{
  "name": "real-estate-watcher",
  "version": "0.1.0",
  "description": "Monitoramento de imóveis residenciais para locação em Santo Antônio da Platina/PR.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "app": "node dist/src/index.js",
    "app:dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "bootstrap": "node dist/src/index.js bootstrap",
    "crawl": "node dist/src/index.js crawl",
    "source-check": "node dist/src/index.js source-check",
    "notify-test": "node dist/src/index.js notify-test",
    "smoke-test": "node dist/src/index.js smoke-test",
    "watch": "node dist/src/index.js watch",
    "run-service": "node dist/src/index.js run-service",
    "healthcheck": "node dist/src/index.js healthcheck",
    "install-browsers": "node dist/src/index.js install-browsers",
    "start": "node dist/src/index.js run-service",
    "db:apply": "node dist/src/scripts/apply-migrations.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "got": "^14.6.5",
    "iconv-lite": "^0.7.0",
    "pino": "^10.1.0",
    "playwright": "^1.55.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
